<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
	fx:controller="com.shale.ui.controller.CaseController">

	<!-- TOP: Header / Command Bar (slightly tighter) -->
	<top>
		<VBox spacing="6.0" BorderPane.alignment="CENTER">
			<padding>
				<Insets top="10" right="12" bottom="8" left="12" />
			</padding>

			<!-- Main header row: (usercard) : Case# -->
			<HBox spacing="8.0" alignment="CENTER_LEFT">

				<!-- Responsible Attorney MINI card -->
				<StackPane fx:id="assignedUserHost" />

				<!-- Colon separator -->
				<Label text=":" style="-fx-font-size: 16px; -fx-opacity: 0.6;" />

				<!-- Case Title -->
				<Label fx:id="caseTitleLabel" text="Case (Placeholder)"
					style="-fx-font-size: 18px; -fx-font-weight: bold;" />

				<Region HBox.hgrow="ALWAYS" />

			</HBox>

			<!-- Secondary row: status + last updated -->
			<HBox spacing="10.0" alignment="CENTER_LEFT">
				<StackPane fx:id="statusHost" />

				<Region HBox.hgrow="ALWAYS" />

				<Label fx:id="lastUpdatedLabel" text="Last updated: —"
					style="-fx-opacity: 0.7;" />
			</HBox>
		</VBox>
	</top>

	<!-- LEFT: Case navigation -->
	<left>
		<VBox spacing="8.0" BorderPane.alignment="TOP_LEFT"
			style="-fx-background-color: rgba(0,0,0,0.03);">
			<padding>
				<Insets top="10" right="10" bottom="10" left="12" />
			</padding>

			<Label text="Sections"
				style="-fx-font-weight: bold; -fx-opacity: 0.8;" />
			<VBox fx:id="sectionButtonsBox" spacing="6.0" prefWidth="200.0" />
		</VBox>
	</left>

	<!-- CENTER: Content area (we switch panes by showing/hiding) -->
	<center>
		<StackPane fx:id="contentHost" BorderPane.alignment="CENTER">
			<padding>
				<Insets top="10" right="12" bottom="12" left="12" />
			</padding>

			<!-- OVERVIEW PANE -->
			<ScrollPane fx:id="overviewScrollPane" fitToWidth="true"
				hbarPolicy="NEVER" style="-fx-background-color: transparent;">
				<VBox fx:id="overviewPane" spacing="10" maxWidth="980">
					<padding>
						<Insets top="12" right="12" bottom="12" left="12" />
					</padding>
					<HBox alignment="CENTER_LEFT" spacing="8">
						<Label fx:id="contentTitleLabel" text="Overview"
							style="-fx-font-size: 16px; -fx-font-weight: bold;" />
						<Region HBox.hgrow="ALWAYS" />
						<Button fx:id="editButton" text="Edit" />
						<Button fx:id="saveButton" text="Save" visible="false"
							managed="false" />
						<Button fx:id="cancelButton" text="Cancel" visible="false"
							managed="false" />
					</HBox>

					<HBox spacing="8" alignment="CENTER_LEFT">
						<Label fx:id="errorLabel" textFill="#b42318" wrapText="true"
							visible="false" managed="false" />
					</HBox>

					<HBox fx:id="remoteUpdateBanner" spacing="8"
						alignment="CENTER_LEFT" visible="false" managed="false">
						<Label text="This case was updated elsewhere."
							style="-fx-text-fill: #b42318;" />
						<Button fx:id="reloadRemoteButton" text="Reload" />
					</HBox>

					<GridPane hgap="14" vgap="8">
						<columnConstraints>
							<ColumnConstraints minWidth="150"
								prefWidth="170" />
							<ColumnConstraints hgrow="ALWAYS" />
						</columnConstraints>

						<Label text="Case name:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="0" GridPane.columnIndex="0" />
						<Label fx:id="ovCaseNameValue" text="—" wrapText="true"
							GridPane.rowIndex="0" GridPane.columnIndex="1" />
						<TextField fx:id="ovCaseNameEditor" visible="false"
							managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />

						<Label text="Case number:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="1" GridPane.columnIndex="0" />
						<Label fx:id="ovCaseNumberValue" text="—" wrapText="true"
							GridPane.rowIndex="1" GridPane.columnIndex="1" />
						<TextField fx:id="ovCaseNumberEditor" visible="false"
							managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />

						<Label text="Responsible atty:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="2" GridPane.columnIndex="0" />

						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="2" GridPane.columnIndex="1">
							<StackPane fx:id="ovResponsibleAttorneyHost" />
							<Button fx:id="changeResponsibleAttorneyButton"
								text="Change" visible="false" managed="false" />
						</HBox>

						<Label text="Case status:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="3" GridPane.columnIndex="0" />
						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="3" GridPane.columnIndex="1">
							<StackPane fx:id="ovCaseStatusHost" />
							<Button fx:id="changeStatusButton" text="Change"
								visible="false" managed="false" />
						</HBox>

						<Label text="Caller:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="4" GridPane.columnIndex="0" />
						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="4" GridPane.columnIndex="1">
							<StackPane fx:id="ovCallerHost" />
							<Button fx:id="changeCallerButton" text="Change"
								visible="false" managed="false" />
						</HBox>

						<Label text="Client:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="5" GridPane.columnIndex="0" />
						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="5" GridPane.columnIndex="1">
							<StackPane fx:id="ovClientHost" />
							<Button fx:id="changeClientButton" text="Change"
								visible="false" managed="false" />
						</HBox>

						<Label text="Practice area:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="6" GridPane.columnIndex="0" />

						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="6" GridPane.columnIndex="1">
							<StackPane fx:id="ovPracticeAreaHost" />
							<Button fx:id="changePracticeAreaButton" text="Change"
								visible="false" managed="false" />
						</HBox>

						<Label text="Opposing Counsel" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="7" GridPane.columnIndex="0" />
						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="7" GridPane.columnIndex="1">
							<StackPane fx:id="ovOpposingCounselHost" />
							<Button fx:id="changeOpposingCounselButton" text="Change"
								visible="false" managed="false" />
						</HBox>

						<Label text="Team:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="8" GridPane.columnIndex="0" />
						<HBox spacing="8" alignment="CENTER_LEFT"
							GridPane.rowIndex="8" GridPane.columnIndex="1">
							<Button fx:id="btnEditTeam" text="Edit Team"
								visible="false" managed="false" onAction="#onEditTeam" />
						</HBox>

						<FlowPane fx:id="teamFlow" hgap="10" vgap="10"
							prefWrapLength="520" GridPane.rowIndex="9"
							GridPane.columnIndex="0" GridPane.columnSpan="2" />

						<Label text="Intake date:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="10" GridPane.columnIndex="0" />
						<Label fx:id="ovIntakeDateValue" text="—"
							GridPane.rowIndex="10" GridPane.columnIndex="1" />

						<Label text="Incident date:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="11" GridPane.columnIndex="0" />
						<Label fx:id="ovIncidentDateValue" text="—"
							GridPane.rowIndex="11" GridPane.columnIndex="1" />
						<DatePicker fx:id="ovIncidentDateEditor"
							visible="false" managed="false" GridPane.rowIndex="11"
							GridPane.columnIndex="1" />

						<Label text="SOL date:" style="-fx-opacity: 0.8;"
							GridPane.rowIndex="12" GridPane.columnIndex="0" />
						<Label fx:id="ovSolDateValue" text="—"
							GridPane.rowIndex="12" GridPane.columnIndex="1" />
						<DatePicker fx:id="ovSolDateEditor" visible="false"
							managed="false" GridPane.rowIndex="12" GridPane.columnIndex="1" />
					</GridPane>

					<Separator />

					<Label text="Case description:"
						style="-fx-font-weight: bold; -fx-opacity: 0.85;" />
					<Label fx:id="ovDescriptionValue" text="" wrapText="true" />
					<TextArea fx:id="ovDescriptionEditor"
						promptText="(description / overview notes)" prefRowCount="6"
						wrapText="true" visible="false" managed="false" />
				</VBox>
			</ScrollPane>

			<!-- DETAILS PANE -->
			<ScrollPane fx:id="detailsScrollPane" fitToWidth="true" hbarPolicy="NEVER" visible="false" managed="false"
				style="-fx-background-color: transparent;">
				<VBox fx:id="detailsPane" spacing="14" maxWidth="980">
					<padding>
						<Insets top="14" right="14" bottom="14" left="14" />
					</padding>
					<HBox alignment="CENTER_LEFT" spacing="10">
						<Label text="Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-opacity: 0.92;" />
						<Region HBox.hgrow="ALWAYS" />
						<Button fx:id="detailsEditButton" text="Edit" />
						<Button fx:id="detailsSaveButton" text="Save" visible="false" managed="false" />
						<Button fx:id="detailsCancelButton" text="Cancel" visible="false" managed="false" />
					</HBox>

					<Label fx:id="detailsErrorLabel" textFill="#b42318" wrapText="true" visible="false" managed="false" />

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Core" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10">
							<columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Name:" GridPane.rowIndex="0" /><Label fx:id="detNameValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><TextField fx:id="detNameEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Case Number:" GridPane.rowIndex="1" /><Label fx:id="detCaseNumberValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><TextField fx:id="detCaseNumberEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
							<Label text="Status:" GridPane.rowIndex="2" /><Label fx:id="detCaseStatusValue" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" />
							<HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="1" fx:id="detCaseStatusEditorRow" visible="false" managed="false"><StackPane fx:id="detCaseStatusHost" /><Button fx:id="detChangeStatusButton" text="Change" /></HBox>
							<Label text="Practice Area:" GridPane.rowIndex="3" /><Label fx:id="detPracticeAreaIdValue" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1" />
							<HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1" fx:id="detPracticeAreaEditorRow" visible="false" managed="false"><StackPane fx:id="detPracticeAreaHost" /><Button fx:id="detChangePracticeAreaButton" text="Change" /></HBox>
							<Label text="Description:" GridPane.rowIndex="4" /><Label fx:id="detDescriptionValue" text="—" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1" /><TextArea fx:id="detDescriptionEditor" prefRowCount="4" wrapText="true" visible="false" managed="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Lifecycle" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10">
							<columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Date of Intake:" GridPane.rowIndex="0" /><Label fx:id="detCallerDateValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><DatePicker fx:id="detCallerDateEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Time of Intake:" GridPane.rowIndex="1" /><Label fx:id="detCallerTimeValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><TextField fx:id="detCallerTimeEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
							<Label text="Date Accepted:" GridPane.rowIndex="2" /><Label fx:id="detAcceptedDateValue" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" /><DatePicker fx:id="detAcceptedDateEditor" visible="false" managed="false" GridPane.rowIndex="2" GridPane.columnIndex="1" />
							<Label text="Date Closed:" GridPane.rowIndex="3" /><Label fx:id="detClosedDateValue" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1" /><DatePicker fx:id="detClosedDateEditor" visible="false" managed="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />
							<Label text="Date Denied:" GridPane.rowIndex="4" /><Label fx:id="detDeniedDateValue" text="—" GridPane.rowIndex="4" GridPane.columnIndex="1" /><DatePicker fx:id="detDeniedDateEditor" visible="false" managed="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Incident &amp; Deadlines" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10"><columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Date of Medical Negligence:" GridPane.rowIndex="0" /><Label fx:id="detDateOfMedicalNegligenceValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><DatePicker fx:id="detDateOfMedicalNegligenceEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Date Medical Negligence Was Discovered:" GridPane.rowIndex="1" /><Label fx:id="detDateMedicalNegligenceWasDiscoveredValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><DatePicker fx:id="detDateMedicalNegligenceWasDiscoveredEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
							<Label text="Date of Injury:" GridPane.rowIndex="2" /><Label fx:id="detDateOfInjuryValue" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" /><DatePicker fx:id="detDateOfInjuryEditor" visible="false" managed="false" GridPane.rowIndex="2" GridPane.columnIndex="1" />
							<Label text="Statute of Limitations:" GridPane.rowIndex="3" /><Label fx:id="detStatuteOfLimitationsValue" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1" /><DatePicker fx:id="detStatuteOfLimitationsEditor" visible="false" managed="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />
							<Label text="Tort Notice Deadline:" GridPane.rowIndex="4" /><Label fx:id="detTortNoticeDeadlineValue" text="—" GridPane.rowIndex="4" GridPane.columnIndex="1" /><DatePicker fx:id="detTortNoticeDeadlineEditor" visible="false" managed="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />
							<Label text="Discovery Deadline:" GridPane.rowIndex="5" /><Label fx:id="detDiscoveryDeadlineValue" text="—" GridPane.rowIndex="5" GridPane.columnIndex="1" /><DatePicker fx:id="detDiscoveryDeadlineEditor" visible="false" managed="false" GridPane.rowIndex="5" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Administrative" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10"><columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Estate Case:" GridPane.rowIndex="0" /><Label fx:id="detClientEstateValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><CheckBox fx:id="detClientEstateEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Office Case Code:" GridPane.rowIndex="1" /><Label fx:id="detOfficePrinterCodeValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><TextField fx:id="detOfficePrinterCodeEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
							<Label text="Medical Records Received:" GridPane.rowIndex="2" /><Label fx:id="detMedicalRecordsReceivedValue" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" /><CheckBox fx:id="detMedicalRecordsReceivedEditor" visible="false" managed="false" GridPane.rowIndex="2" GridPane.columnIndex="1" />
							<Label text="Fee Agreement Signed:" GridPane.rowIndex="3" /><Label fx:id="detFeeAgreementSignedValue" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1" /><CheckBox fx:id="detFeeAgreementSignedEditor" visible="false" managed="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />
							<Label text="Fee Agreement Date:" GridPane.rowIndex="4" /><Label fx:id="detDateFeeAgreementSignedValue" text="—" GridPane.rowIndex="4" GridPane.columnIndex="1" /><DatePicker fx:id="detDateFeeAgreementSignedEditor" visible="false" managed="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Accepted" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10"><columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Chronology:" GridPane.rowIndex="0" /><Label fx:id="detAcceptedChronologyValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><CheckBox fx:id="detAcceptedChronologyEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Consultant Expert Search:" GridPane.rowIndex="1" /><Label fx:id="detAcceptedConsultantExpertSearchValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><CheckBox fx:id="detAcceptedConsultantExpertSearchEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
							<Label text="Testifying Expert Search:" GridPane.rowIndex="2" /><Label fx:id="detAcceptedTestifyingExpertSearchValue" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1" /><CheckBox fx:id="detAcceptedTestifyingExpertSearchEditor" visible="false" managed="false" GridPane.rowIndex="2" GridPane.columnIndex="1" />
							<Label text="Medical Literature:" GridPane.rowIndex="3" /><Label fx:id="detAcceptedMedicalLiteratureValue" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1" /><CheckBox fx:id="detAcceptedMedicalLiteratureEditor" visible="false" managed="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />
							<Label text="Detail:" GridPane.rowIndex="4" /><Label fx:id="detAcceptedDetailValue" text="—" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1" /><TextArea fx:id="detAcceptedDetailEditor" prefRowCount="3" wrapText="true" visible="false" managed="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Denied" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10"><columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Chronology:" GridPane.rowIndex="0" /><Label fx:id="detDeniedChronologyValue" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1" /><CheckBox fx:id="detDeniedChronologyEditor" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Detail:" GridPane.rowIndex="1" /><Label fx:id="detDeniedDetailValue" text="—" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1" /><TextArea fx:id="detDeniedDetailEditor" prefRowCount="3" wrapText="true" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>

					<VBox spacing="12" style="-fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 10; -fx-padding: 14;">
						<Label text="Notes" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
						<GridPane hgap="16" vgap="10"><columnConstraints><ColumnConstraints minWidth="220" prefWidth="240" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
							<Label text="Summary:" GridPane.rowIndex="0" /><Label fx:id="detSummaryValue" text="—" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="1" /><TextArea fx:id="detSummaryEditor" prefRowCount="3" wrapText="true" visible="false" managed="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />
							<Label text="Received Updates:" GridPane.rowIndex="1" /><Label fx:id="detReceivedUpdatesValue" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1" /><CheckBox fx:id="detReceivedUpdatesEditor" visible="false" managed="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />
						</GridPane>
					</VBox>
				</VBox>
			</ScrollPane>
			<!-- TASKS TAB PANE (center) -->
			<VBox fx:id="tasksTabPane" spacing="10" maxWidth="980"
				visible="false" managed="false">
				<Label text="Tasks"
					style="-fx-font-size: 16px; -fx-font-weight: bold;" />
				<TextField fx:id="tasksTabSearchField"
					promptText="Search tasks…" />
				<ListView fx:id="tasksTabListView" prefHeight="520.0" />
				<Label text="(placeholder) Task details / actions go here"
					wrapText="true" style="-fx-opacity: 0.7;" />
			</VBox>

			<!-- GENERIC PLACEHOLDER PANE -->
			<VBox fx:id="genericPane" spacing="10" maxWidth="980"
				visible="false" managed="false">
				<Label fx:id="genericTitleLabel" text="Section"
					style="-fx-font-size: 16px; -fx-font-weight: bold;" />
				<TextArea fx:id="placeholderTextArea"
					promptText="Placeholder notes / testing area" prefRowCount="12" />
			</VBox>

		</StackPane>
	</center>

	<right>
		<VBox spacing="10.0" prefWidth="320.0"
			style="-fx-background-color: rgba(0,0,0,0.03);"
			BorderPane.alignment="TOP_LEFT">
			<padding>
				<Insets top="10" right="12" bottom="12" left="10" />
			</padding>

			<Label text="Updates"
				style="-fx-font-size: 15px; -fx-font-weight: bold;" />

			<TextArea fx:id="caseUpdatesComposerArea"
				promptText="Add a case update..." wrapText="true" prefRowCount="4" />

			<Button fx:id="submitCaseUpdateButton" text="Submit"
				maxWidth="Infinity" />

			<ScrollPane fx:id="caseUpdatesScrollPane"
				fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
				<VBox fx:id="caseUpdatesFeedBox" spacing="8.0">
					<padding>
						<Insets top="2" right="2" bottom="2" left="2" />
					</padding>
				</VBox>
			</ScrollPane>
		</VBox>
	</right>

</BorderPane>
