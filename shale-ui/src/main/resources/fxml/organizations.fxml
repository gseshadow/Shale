<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.shale.ui.controller.OrganizationsController" styleClass="app-shell">

	<top>
		<HBox spacing="10" styleClass="cases-filter-bar strong-panel">
			<padding>
				<Insets top="10" right="10" bottom="10" left="10" />
			</padding>
			<TextField fx:id="organizationsSearchField"
				promptText="Search organizations…" HBox.hgrow="ALWAYS" />
		</HBox>
	</top>

	<center>
		<StackPane>
			<children>
				<ScrollPane fx:id="organizationsScroll" fitToWidth="true"
					pannable="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="surface-scroll">
					<content>
						<FlowPane fx:id="organizationsFlow" hgap="10" vgap="10"
							prefWrapLength="900" styleClass="cases-content-surface glass-panel">
							<padding>
								<Insets top="10" right="10" bottom="10" left="10" />
							</padding>
						</FlowPane>
					</content>
				</ScrollPane>

				<Label fx:id="organizationsEmptyStateLabel"
					text="No organizations to display yet."
					visible="false" managed="false" />
			</children>
		</StackPane>
	</center>

</BorderPane>
