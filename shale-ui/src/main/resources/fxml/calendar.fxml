<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.shale.ui.controller.CalendarController"
      spacing="12"
      styleClass="content-root shell-transparent">
    <children>
        <Label fx:id="calendarTitleLabel" styleClass="section-title" text="Calendar" />
        <Label fx:id="calendarSubtitleLabel" text="Calendar events and case/task deadlines will appear here." wrapText="true" style="-fx-opacity: 0.85;" />
        <VBox spacing="8" styleClass="strong-panel" maxWidth="1.7976931348623157E308">
            <children>
                <Label fx:id="calendarEmptyStateLabel" text="No calendar items to display yet." styleClass="lane-empty-state" wrapText="true" />
            </children>
            <padding>
                <Insets top="18" right="18" bottom="18" left="18" />
            </padding>
        </VBox>
    </children>
</VBox>
