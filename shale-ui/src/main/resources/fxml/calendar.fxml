<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.shale.ui.controller.CalendarController"
      spacing="12"
      styleClass="content-root shell-transparent">
    <children>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="todayButton" text="Today" onAction="#onToday" styleClass="app-toolbar-button app-toolbar-button-compact" />
                <Button fx:id="prevWeekButton" text="◀" onAction="#onPreviousWeek" styleClass="app-toolbar-button app-toolbar-button-compact" />
                <Button fx:id="nextWeekButton" text="▶" onAction="#onNextWeek" styleClass="app-toolbar-button app-toolbar-button-compact" />
                <Label fx:id="weekRangeLabel" styleClass="search-section-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="newEventButton" text="New Event" onAction="#onNewEvent" styleClass="app-toolbar-button app-toolbar-button-compact" />
                <ChoiceBox fx:id="viewModeChoice" styleClass="app-toolbar-select" />
                <TextField fx:id="searchTextField" promptText="Search" prefWidth="180" />
                <ComboBox fx:id="caseFilterCombo" promptText="All cases" prefWidth="170" styleClass="app-toolbar-select" />
                <ComboBox fx:id="eventTypeFilterCombo" promptText="All types" prefWidth="150" styleClass="app-toolbar-select" />
                <Button fx:id="clearFiltersButton" text="Clear Filters" onAction="#onClearFilters" styleClass="app-toolbar-button app-toolbar-button-compact" />
            </children>
        </HBox>

        <Label fx:id="calendarLoadingLabel" text="Loading week..." styleClass="lane-empty-state" visible="false" managed="false" />
        <Label fx:id="calendarErrorLabel" styleClass="error" visible="false" managed="false" />

        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" styleClass="shell-transparent">
            <content>
                <HBox fx:id="weekBoard" spacing="6" styleClass="calendar-week-board">
                    <padding><Insets top="2" right="1" bottom="6" left="1" /></padding>
                </HBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
