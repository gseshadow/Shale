<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.shale.ui.controller.UserController" styleClass="app-shell">

    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="12" bottom="8" left="12" />
            </padding>

            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Label fx:id="userTitleLabel" text="User"
                    style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="editButton" text="Edit" visible="false" managed="false" />
                <Button fx:id="saveButton" text="Save" visible="false" managed="false" />
                <Button fx:id="cancelButton" text="Cancel" visible="false" managed="false" />
            </HBox>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label fx:id="userSubtitleLabel" text="User #—" style="-fx-opacity: 0.8;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="userPermissionLabel" text="Read only" style="-fx-opacity: 0.7;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="12" bottom="12" left="12" />
            </padding>

            <HBox spacing="16" maxWidth="1360" alignment="TOP_LEFT">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12" />
                </padding>

                <VBox spacing="12" styleClass="case-main-surface" minWidth="640" prefWidth="820" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12" />
                    </padding>

                    <Label fx:id="errorLabel" textFill="#b42318" wrapText="true" visible="false" managed="false" />

                    <GridPane hgap="14" vgap="10" style="-fx-alignment: TOP_LEFT;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="160" prefWidth="180" />
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true" />
                        </columnConstraints>

                            <Label text="Display Name:" style="-fx-opacity: 0.8;" GridPane.rowIndex="0" />
                            <Label fx:id="displayNameValue" text="—" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                            <Label text="First Name:" style="-fx-opacity: 0.8;" GridPane.rowIndex="1" />
                            <Label fx:id="firstNameValue" text="—" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            <TextField fx:id="firstNameEditor" visible="false" managed="false" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                            <Label text="Last Name:" style="-fx-opacity: 0.8;" GridPane.rowIndex="2" />
                            <Label fx:id="lastNameValue" text="—" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                            <TextField fx:id="lastNameEditor" visible="false" managed="false" maxWidth="1.7976931348623157E308" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                            <Label text="Email:" style="-fx-opacity: 0.8;" GridPane.rowIndex="3" />
                            <Label fx:id="emailValue" text="—" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                            <TextField fx:id="emailEditor" visible="false" managed="false" maxWidth="1.7976931348623157E308" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                            <Label text="Phone:" style="-fx-opacity: 0.8;" GridPane.rowIndex="4" />
                            <Label fx:id="phoneValue" text="—" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                            <TextField fx:id="phoneEditor" visible="false" managed="false" maxWidth="1.7976931348623157E308" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                            <Label text="Initials:" style="-fx-opacity: 0.8;" GridPane.rowIndex="5" />
                            <Label fx:id="initialsValue" text="—" wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                            <TextField fx:id="initialsEditor" visible="false" managed="false" maxWidth="1.7976931348623157E308" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                            <Label text="Color:" style="-fx-opacity: 0.8;" GridPane.rowIndex="6" />
                            <HBox fx:id="colorValueContainer" spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="6" GridPane.columnIndex="1">
                                <Region fx:id="colorPreview" />
                                <Label fx:id="colorValue" text="—" wrapText="true" />
                            </HBox>
                            <HBox fx:id="colorEditorContainer" spacing="10" alignment="CENTER_LEFT" visible="false" managed="false" GridPane.rowIndex="6" GridPane.columnIndex="1">
                                <ColorPicker fx:id="colorEditor" />
                                <Label fx:id="colorEditorValue" text="—" style="-fx-opacity: 0.8;" />
                            </HBox>

                    </GridPane>

                    <VBox spacing="10" styleClass="secondary-panel">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12" />
                        </padding>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Roles" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="addRoleButton" text="Add Role" visible="false" managed="false" />
                        </HBox>
                        <FlowPane fx:id="rolesFlow" hgap="8" vgap="8" prefWrapLength="720" />
                        <Label fx:id="rolesEmptyLabel" text="No roles assigned" visible="false" managed="false" style="-fx-opacity: 0.75;" />
                    </VBox>
                </VBox>

                <VBox prefWidth="420" minWidth="360" maxWidth="500" maxHeight="1.7976931348623157E308" spacing="10" styleClass="secondary-panel" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12" />
                    </padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Assigned Tasks" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="assignedTasksSearchField" promptText="Search assigned tasks…" HBox.hgrow="ALWAYS" />
                        <ChoiceBox fx:id="assignedTasksSortChoice" prefWidth="180" />
                    </HBox>
                    <ScrollPane fx:id="assignedTasksScroll" fitToWidth="true" hbarPolicy="NEVER" styleClass="surface-scroll" VBox.vgrow="ALWAYS">
                        <StackPane>
                            <VBox fx:id="assignedTasksContainer" spacing="10" fillWidth="true" maxWidth="1.7976931348623157E308" />
                            <Label fx:id="assignedTasksEmptyLabel" text="No assigned tasks" visible="false" managed="false" />
                        </StackPane>
                    </ScrollPane>
                </VBox>

                <VBox prefWidth="420" minWidth="360" maxWidth="500" maxHeight="1.7976931348623157E308" spacing="10" styleClass="secondary-panel" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="12" right="12" bottom="12" left="12" />
                    </padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Assigned Cases" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="assignedCasesSearchField" promptText="Search assigned cases…" HBox.hgrow="ALWAYS" />
                        <ChoiceBox fx:id="assignedCasesSortChoice" prefWidth="180" />
                    </HBox>
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="surface-scroll" VBox.vgrow="ALWAYS">
                        <StackPane>
                            <VBox fx:id="assignedCasesContainer" spacing="10" fillWidth="true" maxWidth="1.7976931348623157E308" />
                            <Label fx:id="assignedCasesEmptyLabel" text="No assigned cases" visible="false" managed="false" />
                        </StackPane>
                    </ScrollPane>
                </VBox>
            </HBox>
        </StackPane>
    </center>

</BorderPane>
