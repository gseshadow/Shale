<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.shale.ui.controller.NewOrganizationController"
      spacing="12"
      prefWidth="760" prefHeight="720"
      styleClass="form-surface">

    <padding>
        <Insets top="14" right="14" bottom="14" left="14" />
    </padding>

    <children>
        <Label text="New Organization" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <Label fx:id="validationLabel" textFill="#b42318" wrapText="true" visible="false" managed="false" />

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="12" maxWidth="720">
                    <padding>
                        <Insets top="8" right="4" bottom="8" left="4" />
                    </padding>

                    <VBox spacing="10" styleClass="secondary-panel">
                        <Label text="Organization" style="-fx-font-weight: bold; -fx-opacity: 0.9;" />
                        <GridPane hgap="16" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="180" prefWidth="200" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                            <Label text="Name" GridPane.rowIndex="0" />
                            <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                            <Label text="Organization Type" GridPane.rowIndex="1" />
                            <ComboBox fx:id="organizationTypeComboBox" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                            <Label text="Phone" GridPane.rowIndex="2" />
                            <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                            <Label text="Fax" GridPane.rowIndex="3" />
                            <TextField fx:id="faxField" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                            <Label text="Email" GridPane.rowIndex="4" />
                            <TextField fx:id="emailField" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                            <Label text="Website" GridPane.rowIndex="5" />
                            <TextField fx:id="websiteField" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                            <Label text="Address1" GridPane.rowIndex="6" />
                            <TextField fx:id="address1Field" GridPane.rowIndex="6" GridPane.columnIndex="1" />

                            <Label text="Address2" GridPane.rowIndex="7" />
                            <TextField fx:id="address2Field" GridPane.rowIndex="7" GridPane.columnIndex="1" />

                            <Label text="City" GridPane.rowIndex="8" />
                            <TextField fx:id="cityField" GridPane.rowIndex="8" GridPane.columnIndex="1" />

                            <Label text="State" GridPane.rowIndex="9" />
                            <TextField fx:id="stateField" GridPane.rowIndex="9" GridPane.columnIndex="1" />

                            <Label text="Postal Code" GridPane.rowIndex="10" />
                            <TextField fx:id="postalCodeField" GridPane.rowIndex="10" GridPane.columnIndex="1" />

                            <Label text="Country" GridPane.rowIndex="11" />
                            <TextField fx:id="countryField" GridPane.rowIndex="11" GridPane.columnIndex="1" />

                            <Label text="Notes" GridPane.rowIndex="12" />
                            <TextArea fx:id="notesArea" prefRowCount="4" wrapText="true" GridPane.rowIndex="12" GridPane.columnIndex="1" />
                        </GridPane>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="cancelButton" text="Cancel" onAction="#onCancel" />
            <Button fx:id="createOrganizationButton" text="Create Organization" onAction="#onCreateOrganization" />
        </HBox>
    </children>
</VBox>
