<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.shale.ui.controller.MyShaleController" styleClass="app-shell">
	<left>
		<VBox spacing="8.0" BorderPane.alignment="TOP_LEFT" styleClass="case-nav-pane nav-rail">
			<padding>
				<Insets top="10" right="10" bottom="10" left="12" />
			</padding>
			<Label text="Sections" styleClass="sidebar-header" />
			<VBox fx:id="sectionButtonsBox" spacing="6.0" minWidth="100.0" prefWidth="100.0" maxWidth="100.0" />
		</VBox>
	</left>
		<center>
			<StackPane fx:id="sectionContentStack" BorderPane.alignment="CENTER" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
				<padding>
					<Insets top="10" right="12" bottom="12" left="12" />
				</padding>

				<VBox fx:id="overviewSectionPane" spacing="10" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
					<ScrollPane fx:id="overviewScroll" fitToWidth="true" pannable="true" hbarPolicy="NEVER"
						vbarPolicy="AS_NEEDED" styleClass="surface-scroll" VBox.vgrow="ALWAYS">
						<content>
							<VBox fx:id="overviewMainRow" spacing="10" fillWidth="true" />
						</content>
					</ScrollPane>
				</VBox>

				<VBox fx:id="tasksSectionPane" spacing="8" visible="false" managed="false" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
					<VBox fx:id="tasksSectionContentHost" VBox.vgrow="ALWAYS" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
						<VBox fx:id="myTasksPanel" spacing="8" styleClass="strong-panel" prefWidth="430" minWidth="390" VBox.vgrow="ALWAYS" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
						<padding>
							<Insets top="10" right="10" bottom="10" left="10" />
						</padding>
						<VBox spacing="8">
							<HBox spacing="8" alignment="CENTER_LEFT">
								<Label text="My Tasks" styleClass="page-heading" />
								<Region HBox.hgrow="ALWAYS" />
							</HBox>
							<HBox spacing="10" alignment="TOP_LEFT">
								<VBox spacing="4" styleClass="glass-panel" HBox.hgrow="ALWAYS">
									<padding>
										<Insets top="8" right="10" bottom="8" left="10" />
									</padding>
									<Label text="Task Controls">
										<styleClass>
											<String fx:value="sidebar-header" />
											<String fx:value="my-shale-tasks-controls-label" />
										</styleClass>
									</Label>
									<HBox spacing="8" alignment="CENTER_LEFT">
										<ChoiceBox fx:id="myTasksSortChoice" prefWidth="170">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
										<Button fx:id="myTasksShowCompletedButton" text="Show Completed">
											<styleClass>
												<String fx:value="app-toolbar-button" />
												<String fx:value="app-toolbar-button-neutral" />
											</styleClass>
										</Button>
										<ChoiceBox fx:id="myTasksPriorityFilterChoice" prefWidth="190">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
									</HBox>
								</VBox>
								<VBox spacing="4" styleClass="glass-panel">
									<padding>
										<Insets top="8" right="10" bottom="8" left="10" />
									</padding>
									<Label text="Lane Controls">
										<styleClass>
											<String fx:value="sidebar-header" />
											<String fx:value="my-shale-tasks-controls-label" />
										</styleClass>
									</Label>
									<HBox spacing="8" alignment="CENTER_LEFT">
										<Label text="Cases" />
										<ChoiceBox fx:id="myTasksCaseFilterChoice" prefWidth="180">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
										<ChoiceBox fx:id="myTasksColumnOrderChoice" prefWidth="220">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
									</HBox>
								</VBox>
							</HBox>
							<HBox spacing="8" alignment="CENTER_LEFT">
								<TextField fx:id="myTasksSearchField" promptText="Search my tasks…" HBox.hgrow="ALWAYS" />
							</HBox>
						</VBox>
						<Label fx:id="myTasksEmptyLabel" text="No tasks assigned to you." managed="false" visible="false" />
						<ScrollPane fx:id="myTasksScroll" fitToHeight="true" pannable="true" hbarPolicy="AS_NEEDED"
							vbarPolicy="NEVER" styleClass="surface-scroll" VBox.vgrow="ALWAYS">
							<content>
								<HBox fx:id="myTasksList" spacing="10" styleClass="cases-content-surface glass-panel">
									<padding>
										<Insets top="10" right="10" bottom="18" left="10" />
									</padding>
								</HBox>
							</content>
						</ScrollPane>
					</VBox>
					</VBox>
				</VBox>

				<VBox fx:id="myCasesSectionPane" spacing="8" visible="false" managed="false" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
					<VBox fx:id="myCasesSectionContentHost" VBox.vgrow="ALWAYS" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
						<VBox spacing="8" styleClass="strong-panel" prefWidth="430" minWidth="390" VBox.vgrow="ALWAYS" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
							<padding>
								<Insets top="10" right="10" bottom="10" left="10" />
							</padding>
							<HBox spacing="8" alignment="CENTER_LEFT">
								<Label text="My Cases" styleClass="page-heading" />
								<Region HBox.hgrow="ALWAYS" />
							</HBox>
							<HBox spacing="10" alignment="TOP_LEFT">
								<VBox spacing="4" styleClass="glass-panel" HBox.hgrow="ALWAYS">
									<padding>
										<Insets top="8" right="10" bottom="8" left="10" />
									</padding>
									<Label text="Case Controls">
										<styleClass>
											<String fx:value="sidebar-header" />
											<String fx:value="my-shale-tasks-controls-label" />
										</styleClass>
									</Label>
									<HBox spacing="8" alignment="CENTER_LEFT">
										<TextField fx:id="myCasesBoardSearchField" promptText="Search case name or case number…" HBox.hgrow="ALWAYS" />
										<ChoiceBox fx:id="myCasesBoardStatusFilterChoice" prefWidth="200">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
										<ChoiceBox fx:id="myCasesBoardSortChoice" prefWidth="220">
											<styleClass>
												<String fx:value="app-toolbar-select" />
											</styleClass>
										</ChoiceBox>
									</HBox>
								</VBox>
							</HBox>
							<Label fx:id="myCasesBoardEmptyLabel" text="No cases assigned to you." managed="false" visible="false" />
							<ScrollPane fx:id="myCasesBoardScroll" fitToHeight="true" pannable="true" hbarPolicy="AS_NEEDED"
								vbarPolicy="NEVER" styleClass="surface-scroll" VBox.vgrow="ALWAYS">
								<content>
									<HBox fx:id="myCasesBoardList" spacing="10" styleClass="cases-content-surface glass-panel">
										<padding>
											<Insets top="10" right="10" bottom="18" left="10" />
										</padding>
									</HBox>
								</content>
							</ScrollPane>
						</VBox>
					</VBox>
				</VBox>
		</StackPane>
	</center>
</BorderPane>
