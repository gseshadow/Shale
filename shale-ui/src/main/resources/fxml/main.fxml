<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="com.shale.ui.controller.MainController" styleClass="app-shell">

	<!-- Top bar -->
	<top>
		<HBox spacing="12" styleClass="top-bar app-header">
			<children>
				<Button fx:id="backButton" text="←" onAction="#onBack" disable="true"
					styleClass="topbar-back-button" />
				<!-- Global search -->
				<TextField fx:id="globalSearchField"
					promptText="Search cases, contacts, tasks..." HBox.hgrow="ALWAYS" />
				<Button fx:id="globalSearchButton" text="Search"
					onAction="#onGlobalSearch">
					<styleClass>
						<String fx:value="button" />
						<String fx:value="app-toolbar-button" />
						<String fx:value="app-toolbar-button-neutral" />
					</styleClass>
				</Button>

				<Button fx:id="newIntakeButton" text="New Intake"
					onAction="#onNewIntake">
					<styleClass>
						<String fx:value="button" />
						<String fx:value="app-toolbar-button" />
						<String fx:value="app-toolbar-button-primary" />
					</styleClass>
				</Button>


				<Region HBox.hgrow="ALWAYS" />
				<HBox spacing="8" alignment="CENTER_RIGHT">
					<children>
						<HBox fx:id="notificationBannerHost" spacing="8" alignment="CENTER_LEFT"
							styleClass="notification-banner-host" visible="false" managed="false">
							<children>
								<Label fx:id="notificationBannerLabel" text="Update available"
									styleClass="notification-banner-label" />
							</children>
						</HBox>
						<Button fx:id="notificationBellButton" text="🔔"
							onAction="#onOpenNotificationCenter" styleClass="notification-bell-button" />
					</children>
				</HBox>
			</children>
			<padding>
				<Insets top="8" right="12" bottom="8" left="12" />
			</padding>
		</HBox>
	</top>

	<!-- Left navigation sidebar -->
	<left>
		<VBox spacing="6" styleClass="sidebar nav-rail">
			<children>
				<Label text="Navigation" styleClass="sidebar-header" />

				<Button fx:id="navMyShaleButton" text="My Shale"
					maxWidth="Infinity" onAction="#onNavMyShale" />

				<Button fx:id="navCasesButton" text="Cases"
					maxWidth="Infinity" onAction="#onNavCases" />

				<Button fx:id="navContactsButton" text="Contacts"
					maxWidth="Infinity" onAction="#onNavContacts" />

				<Button fx:id="navOrganizationsButton" text="Organizations"
					maxWidth="Infinity" onAction="#onNavOrganizations" />

				<Button fx:id="navTeamButton" text="Team" maxWidth="Infinity"
					onAction="#onNavTeam" />

				<Button fx:id="navCalendarButton" text="Calendar"
					maxWidth="Infinity" onAction="#onNavCalendar" />

				<Button fx:id="navSettingsButton" text="Settings"
					maxWidth="Infinity" onAction="#onNavSettings" />
			</children>
			<padding>
				<Insets top="10" right="8" bottom="10" left="8" />
			</padding>
		</VBox>
	</left>

	<!-- Main content area (shell-controlled) -->
	<center>
		<VBox spacing="6" styleClass="content-root shell-transparent">
			<children>
				<VBox fx:id="sectionHeaderBox" spacing="2">
					<children>
						<Label fx:id="sectionTitleLabel" text="My Shale"
							styleClass="section-title" />
						<Label fx:id="sectionSubtitleLabel" wrapText="true"
							text="Select a section from the left to get started."
							style="-fx-opacity: 0.8;" />
					</children>
				</VBox>

				<!-- Shell-controlled content placeholder -->
				<StackPane fx:id="sectionContent">
					<children>
						<Label fx:id="placeholderLabel"
							text="This section is not implemented yet." />
					</children>
				</StackPane>
			</children>
			<padding>
				<Insets top="10" right="16" bottom="16" left="16" />
			</padding>
		</VBox>
	</center>

	<bottom>
		<HBox spacing="8" alignment="CENTER_LEFT" styleClass="session-footer">
			<children>
				<Label text="Signed in as:" />
				<Label fx:id="userEmailLabel" text="user@example.com"
					styleClass="user-email" />
				<Button fx:id="logoutButton" text="Logout"
					onAction="#onLogout">
					<styleClass>
						<String fx:value="button" />
						<String fx:value="app-toolbar-button" />
						<String fx:value="app-toolbar-button-neutral" />
						<String fx:value="app-toolbar-button-compact" />
					</styleClass>
				</Button>
			</children>
			<padding>
				<Insets top="8" right="12" bottom="8" left="12" />
			</padding>
		</HBox>
	</bottom>
</BorderPane>
